# =============================================================================
# EDI Text Intelligence — Environment Variables
# Copy to .env and fill in values
# =============================================================================

# Database
DATABASE_URL=postgresql://edi:password@localhost:5432/edi_dev

# Encryption
ENCRYPTION_MASTER_KEY=<32-byte hex — generate with: openssl rand -hex 32>
ENCRYPTION_KEY_VERSION=1

# Auth (API session)
SESSION_SECRET=<64-byte hex — generate with: openssl rand -hex 64>
SESSION_DURATION_HOURS=24
REFRESH_TOKEN_DURATION_DAYS=30

# Auth (NextAuth / web app)
AUTH_SECRET=<32-byte hex — generate with: openssl rand -hex 32>
OAUTH_INTERNAL_SECRET=<random secret shared between web and API to protect /oauth/signin>
AUTH_COOKIE_DOMAIN=<your domain in production, e.g. example.com — omit for localhost>

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft Entra ID (optional — omit to disable Microsoft login)
AUTH_MICROSOFT_ENTRA_ID_ID=<Application (client) ID from Azure portal>
AUTH_MICROSOFT_ENTRA_ID_SECRET=<Client secret value from Azure portal>
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# API
API_PORT=3001
API_CORS_ORIGINS=http://localhost:3000,chrome-extension://<id>

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@edi.app

# App URLs
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
EXTENSION_ID=<chrome extension id for CORS>

# Feature flags
ENABLE_MANAGED_MODE=false
ENABLE_AI_VALIDATION=true
DEFAULT_DAILY_AI_QUOTA=100

# Observability
LOG_LEVEL=info
