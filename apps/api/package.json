{
  "name": "@edi/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@edi/shared": "workspace:*",
    "@hono/node-server": "^1.11.0",
    "@node-rs/argon2": "^2.0.2",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.31.0",
    "hono": "^4.4.0",
    "pg": "^8.12.0",
    "pg-boss": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.22.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
