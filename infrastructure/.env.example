# =============================================================================
# Infrastructure Environment Variables
# Copy to .env for local Docker development
# =============================================================================

# Database
DATABASE_URL=postgresql://edi:password@postgres:5432/edi_dev

# Encryption
ENCRYPTION_MASTER_KEY=<32-byte hex — generate with: openssl rand -hex 32>
ENCRYPTION_KEY_VERSION=1

# Auth
SESSION_SECRET=<64-byte hex — generate with: openssl rand -hex 64>
SESSION_DURATION_HOURS=24
REFRESH_TOKEN_DURATION_DAYS=30

# API
API_PORT=3001
API_CORS_ORIGINS=http://localhost:3000

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@edi.app

# App URLs
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
EXTENSION_ID=<chrome extension id for CORS>

# Feature flags
ENABLE_MANAGED_MODE=false
ENABLE_AI_VALIDATION=true
DEFAULT_DAILY_AI_QUOTA=100

# Observability
LOG_LEVEL=info
